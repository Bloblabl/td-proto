# Пример env для прод-сервера. Скопируйте в server/.env и заполните.
# server/.env в .gitignore — реальные секреты в репозиторий не попадают.

# Порт локального Node-процесса (nginx проксирует сюда). НЕ открывайте наружу.
PORT=3000

# Интерфейс прослушивания. За nginx — только localhost.
HOST=127.0.0.1

# Секрет подписи JWT. Сгенерируйте свой: `openssl rand -hex 32`
JWT_SECRET=ЗАМЕНИТЕ_НА_openssl_rand_hex_32

# Разрешённые origin'ы CORS (через запятую). Origin фронта на GitHub Pages:
ALLOWED_ORIGIN=https://bloblabl.github.io

# Путь к файлу БД (SQLite). Держите вне каталога с кодом, чтобы деплой не затирал.
TD_DB_PATH=/var/lib/td-proto/td.db
